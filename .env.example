# When ENVIRONMENT is unset, the app defaults to production-like behavior.
# For local development, set this explicitly:
ENVIRONMENT=development
#
# DATABASE_URL=sqlite:///./data/edumedia.db
# PostgreSQL (same URL pattern as docker-compose; use host `db` only inside Compose):
#   postgresql+psycopg://edumedia:edumedia@db:5432/edumedia
# MEDIA_UPLOAD_DIR=./data/uploads
# SQLALCHEMY_ECHO=false
#
# Demo only: wipe and recreate SQLite schema on an interval (seconds). 0 = disabled.
# SQLITE_AUTO_RESET_SECONDS=3600
# SQLITE_AUTO_RESET_SEED=true
# Set SQLITE_AUTO_RESET_SEED=false to skip re-seeding after each auto-reset.
#
# Internal usage tracker (optional): set a strong shared secret to enable `/tracker` UI + request logging.
# Omitted = tracker disabled (404 on `/tracker`, no logging overhead).
# TRACKER_SECRET=
# Optional cap on stored request rows (default 50000).
# TRACKER_MAX_ROWS=50000
